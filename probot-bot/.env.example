# probot-bot runtime configuration. Copy to .env.local. All values are
# server-side only - never expose them to the browser.

# The ProBot platform base URL (where /api/v1/bot/* lives).
PROBOT_API_URL=https://pro-bot.dev

# The bot token minted in the dashboard (Settings -> Deployment -> Generate
# token). Shown once; format pbt_<64 hex>.
PROBOT_BOT_TOKEN=

# This runtime calls the LLM itself against any OpenAI-compatible endpoint.
# Configure the provider here; the platform never sees these values.
#
#   PROBOT_LLM_BASE_URL - default https://api.openai.com/v1
#                         local Ollama: http://localhost:11434/v1  (fully free)
#                         Grok (xAI):   https://api.x.ai/v1
#   PROBOT_LLM_MODEL    - default gpt-4o-mini  (e.g. llama3.2, grok-4.3)
#   PROBOT_LLM_API_KEY  - your provider key; any value for local Ollama
PROBOT_LLM_BASE_URL=
PROBOT_LLM_MODEL=
PROBOT_LLM_API_KEY=

# Optional: an embedding key forwarded to the platform's knowledge endpoint to
# enable vector retrieval. When unset, the platform returns the bot's full
# assembled context instead.
PROBOT_EMBEDDING_API_KEY=
