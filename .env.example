# Platform-level secrets only.
# ProBot ships NO default LLM credentials. Each user supplies their own LLM API
# key via the browser; the server never persists it. See claude/plan.md §1.5.

DATABASE_URL=postgresql://user:password@localhost:5432/probot
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Magic-link email sender (Resend HTTP API).
# Free tier: 100 emails/day, 3,000/month. resend.com
# EMAIL_FROM uses Resend's onboarding domain by default; switch to your own
# verified domain (e.g. "ProBot <hello@probot.dev>") once DNS is set up.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=ProBot <onboarding@resend.dev>

# OAuth: GitHub.
# Create at https://github.com/settings/developers (New OAuth App).
# Callback URL: ${NEXTAUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OAuth: Google.
# Create at https://console.cloud.google.com (APIs & Services → Credentials).
# Authorized redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional self-host fallback (NOT used by hosted probot.com).
PROBOT_DEFAULT_LLM_PROVIDER=anthropic
PROBOT_DEFAULT_LLM_MODEL=claude-haiku-4-5
PROBOT_DEFAULT_LLM_API_KEY=

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview
