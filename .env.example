# Platform-level secrets only.
# ProBot ships NO default LLM credentials. Each user supplies their own LLM API
# key via the browser; the server never persists it. See claude/plan.md §1.5.

DATABASE_URL=postgresql://user:password@localhost:5432/probot
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Magic-link email sender (Resend HTTP API).
# Free tier: 100 emails/day, 3,000/month. resend.com
# EMAIL_FROM uses Resend's onboarding domain by default; switch to your own
# verified domain (e.g. "ProBot <hello@pro-bot.dev>") once DNS is set up.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=ProBot <onboarding@resend.dev>

# OAuth: GitHub.
# Create at https://github.com/settings/developers (New OAuth App).
# Callback URL: ${NEXTAUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OAuth: Google.
# Create at https://console.cloud.google.com (APIs & Services → Credentials).
# Authorized redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional self-host fallback (NOT used by hosted pro-bot.dev).
PROBOT_DEFAULT_LLM_PROVIDER=anthropic
PROBOT_DEFAULT_LLM_MODEL=claude-haiku-4-5
PROBOT_DEFAULT_LLM_API_KEY=

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Stage 7 Phase 3: Key Encryption Key for the managed-key flow.
#
# Required ONLY if you want recruiters to chat with a creator's bot when
# the creator's browser is offline (i.e. the dashboard's "store key on
# server, encrypted" path). Self-host operators who only need the BYO-key-
# in-browser path can leave this unset; the "store on server" UI will
# surface a clear 503 with no DB writes.
#
# Generate with:  openssl rand -base64 32
# Must decode to exactly 32 bytes (256-bit AES key). The app validates the
# length at startup when set, so a malformed value fails fast in deploy.
#
# Rotation: deploy with both PROBOT_KEY_ENCRYPTION_KEY (old) and
# PROBOT_KEY_ENCRYPTION_KEY_NEXT (new), run the rotation utility once,
# then swap so NEXT becomes the current KEK and the old is removed.
PROBOT_KEY_ENCRYPTION_KEY=
PROBOT_KEY_ENCRYPTION_KEY_NEXT=

# Stage 7 Phase 5: Bearer secret required by the Vercel Cron handler at
# /api/cron/purge-deleted-accounts. Vercel Cron sets `Authorization:
# Bearer $CRON_SECRET` automatically when this env var is configured in
# the project. Fail-closed: if unset, the route 503s and the daily purge
# does not run (no scheduled deletions are processed). Generate with:
#   openssl rand -base64 32
CRON_SECRET=

# Optional: embed URL for the landing-page "Watch demo" modal (e.g. a YouTube
# embed URL like https://www.youtube.com/embed/<id>). Build-time, public. When
# unset the modal shows a "demo coming soon" poster instead of a broken embed.
NEXT_PUBLIC_DEMO_VIDEO_URL=
